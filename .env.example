# Пример переменных окружения для Telegram-ботов в RSSv7 / RSS4SALE.
# Скопируйте в локальный .env (файл .env уже исключён из git) и заполните реальными значениями.

RSSV7_LD_PROBLEMS_BOT_TOKEN=
RSSV7_LD_PROBLEMS_CHAT_ID=
RSSV7_LD_CHECK_BOT_TOKEN=
RSSV7_LD_CHECK_CHAT_ID=
RSSV7_BOL_DETECT_SSH_BOT_TOKEN=
RSSV7_BOL_DETECT_SSH_CHAT_ID=
RSSV7_OVPN_WATCHER_BOT_TOKEN=
RSSV7_OVPN_WATCHER_CHAT_ID=
GNLDCHECK_TELEGRAM_TOKEN=
GNLDCHECK_THREAD_ID=
GNLDCHECK_CHAT_ID=

RSS4SALE_LD_CHECK_BOT_TOKEN=
RSS4SALE_LD_CHECK_CHAT_ID=
RSS4SALE_LD_PROBLEMS_BOT_TOKEN=
RSS4SALE_LD_PROBLEMS_CHAT_ID=
